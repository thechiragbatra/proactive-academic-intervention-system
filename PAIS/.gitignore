# Project runtime artefacts — regenerated on every boot by main.py
# Keep them OUT of git so the repo stays small, Render rebuilds them at deploy.
data/processed/
webapp/uploads/*
!webapp/uploads/.gitkeep

# Persisted edits + notification log — runtime state, not source
reports/edits_overlay.jsonl
reports/notifications.jsonl

# Keep the trained model + figures + training report checked in, so the
# website has content on first deploy without needing `main.py` to re-run
# on every build. Remove these three lines if you'd rather regenerate.
# models/*.pkl
# reports/figures/*.png
# reports/training_report.json

# OS junk
Thumbs.db
.DS_Store
